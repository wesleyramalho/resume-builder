  "metadata": {
    "defaultTitle": "MyPDFCV — Free Resume Builder",
    "description": "Build professional resumes with real-time preview, 7 templates, and free PDF export in multiple languages. No paywall, no sign-up. 100% free and open source.",
    "landingTitle": "Free Resume Builder — No Sign-up Required",
    "landingDescription": "Create professional resumes with real-time preview, 7 free templates, AI text improvement, and one-click PDF export in multiple languages. Your data stays in your browser."
  },
