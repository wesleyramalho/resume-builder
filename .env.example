# next-auth
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# LinkedIn OAuth App credentials
# Register at: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email
# For local dev callback, configure:
# http://localhost:3000/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Set true only when LinkedIn OAuth credentials are configured.
NEXT_PUBLIC_LINKEDIN_OAUTH_ENABLED=false

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
