{
  "name": "mypdfcv",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:packages": "npm -w packages/i18n run build && npm -w packages/pdf run build",
    "dev": "next dev",
